# services/api — пример окружения. Скопируй в .env.
# Postgres локально даёт Supabase CLI (порт 54322), коннект под postgres/bypassrls.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
REDIS_URL=redis://localhost:6379/0

# Supabase service_role — из вывода `supabase status` (локально) или дашборда (прод).
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

# LLM-провайдеры (через LiteLLM). Для скоринга достаточно GEMINI_API_KEY.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Роутинг моделей по стадиям (главный рычаг юнит-экономики)
LLM_MODEL_SCORE=gemini/gemini-2.0-flash-lite
LLM_MODEL_DRAFT=openai/gpt-5-mini

# LiteLLM proxy. Пусто = прямой SDK-вызов; иначе роутинг через self-host proxy.
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=sk-local-master

# Langfuse. Включи трейс локально: LANGFUSE_ENABLED=true (ключи бутстрапит compose).
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_HOST=http://localhost:3001

FIRECRAWL_API_KEY=

# Ingestion (M1): identifiable UA, троттлинг и пороги скрапинга.
USER_AGENT=KateSearchesBot/1.0 (+https://katesearches.com/bot)
FETCH_TIMEOUT_SECONDS=15
DEFAULT_RATE_LIMIT_RPM=60
EXTRACT_BODY_MIN_CHARS=500
NEAR_DUP_HAMMING_THRESHOLD=3
FIRECRAWL_COST_PER_CALL_USD=0.002
# Гейты robots/throttle. Выключить в оффлайн-тестах: INGESTION_GUARDS_ENABLED=false
INGESTION_GUARDS_ENABLED=true
