# apps/web — пример окружения. Скопируй в .env.local
# Локально значения — из вывода `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role — только на сервере (провижининг тенанта при регистрации). НЕ NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# адрес FastAPI-сервиса
API_BASE_URL=http://localhost:8000

# Базовый URL приложения (redirect Stripe Checkout/Portal, ссылки в письмах)
APP_BASE_URL=http://localhost:3000

# Stripe (M6.2) — только сервер, НЕ NEXT_PUBLIC. Режим выводится из префикса ключа: sk_test_
# на soft-launch (test mode на проде, live-charge невозможен), sk_live_ после флипа. Price-иды
# различаются по режимам, поэтому всегда через env. Вебхук приземляется на web (/api/stripe/webhook).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
