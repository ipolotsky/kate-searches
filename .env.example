# ─── Корневой пример окружения. Скопируй в .env и заполни. НЕ коммить .env ───

# Postgres — локально его даёт Supabase CLI (supabase start), порт 54322.
# Коннект под ролью postgres (bypassrls) — для пайплайна/админки под service_role.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Redis (Celery broker/backend)
REDIS_URL=redis://localhost:6379/0

# Supabase. Локально ключи — из вывода `supabase status` (anon/service_role).
# Прод — из дашборда hosted-проекта (см. docs/HANDOFF.md).
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Адрес FastAPI-сервиса. Web ходит сюда через BFF (server actions), НЕ NEXT_PUBLIC.
API_BASE_URL=http://localhost:8000

# LLM-провайдеры. Для локального скоринга достаточно GEMINI_API_KEY.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Роутинг моделей по стадиям пайплайна
LLM_MODEL_SCORE=gemini/gemini-flash-lite-latest
LLM_MODEL_DRAFT=openai/gpt-5-mini

# LiteLLM proxy (docker-compose). Пусто = api зовёт SDK напрямую.
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=sk-local-master

# Langfuse (cost-metering). Локально бутстрапится docker-compose с этими ключами.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_HOST=http://localhost:3001

# Скрапинг (Firecrawl — fallback, опционально)
FIRECRAWL_API_KEY=

# Гейты тестов (см. Makefile: test-integration):
# RUN_DB_TESTS=1 — интеграционные тесты против Supabase CLI
# RUN_LIVE_LLM=1 — реальный вызов LLM (нужен ключ провайдера)
