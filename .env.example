# ─── Корневой пример окружения. Скопируй в .env и заполни. НЕ коммить .env ───

# Postgres (локальный docker-compose)
POSTGRES_USER=kate
POSTGRES_PASSWORD=kate
POSTGRES_DB=katesearches
DATABASE_URL=postgresql://kate:kate@localhost:5432/katesearches

# Redis (Celery broker/backend)
REDIS_URL=redis://localhost:6379/0

# Supabase (взять из дашборда проекта Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM-провайдеры (через LiteLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Роутинг моделей по стадиям пайплайна
LLM_MODEL_SCORE=gemini/gemini-2.0-flash-lite
LLM_MODEL_DRAFT=openai/gpt-5-mini

# Langfuse (cost-metering). Self-host или cloud.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Скрапинг (Firecrawl — fallback, опционально)
FIRECRAWL_API_KEY=
