# Шаблон .env для окружения на VM. Копируется в /srv/kate-searches/{prod,staging}/.env,
# заполняется руками, chmod 600. В git реальные значения НЕ коммитим — только этот пример.
# Один .env общий для web/api/worker/beat (env_file в compose). REDIS_URL/API_BASE_URL/PORT
# задаются в compose.yml, здесь их не дублируем.

# --- окружение ---
STACK=kate-prod                 # kate-prod | kate-staging (= COMPOSE_PROJECT_NAME)
DOMAIN=taskyou.me               # прод: taskyou.me | staging: staging.taskyou.me
WEB_TAG=prod-bootstrap          # перезаписывается deploy.sh на каждый выкат
API_TAG=prod-bootstrap          # перезаписывается deploy.sh на каждый выкат

# --- Supabase (свой проект на каждое окружение) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- LLM-провайдеры ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_MODEL_SCORE=gemini/gemini-2.0-flash-lite
LLM_MODEL_DRAFT=openai/gpt-5-mini

# --- метеринг/шлюз (в MVP-проде можно не поднимать: прямой SDK, метеринг выключен) ---
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- скрапинг ---
FIRECRAWL_API_KEY=
USER_AGENT=KateSearchesBot/1.0 (+https://taskyou.me)
